{
  "name": "quizzty",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "bun run --filter api prisma:generate",
    "db:migrate": "bun run --filter api prisma:migrate",
    "db:studio": "bun run --filter api prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.4.0"
  },
  "packageManager": "bun@1.3.2"
}
